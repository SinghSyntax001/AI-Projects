# ==========================================
# DataFinder-AI Configuration
# ==========================================

# ==========================================
# Core Application Settings
# ==========================================
APP_NAME=DataFinder-AI
APP_ENV=development
DEBUG=false
API_KEY=your-secret-api-key-here

# ==========================================
# Database Configuration
# ==========================================
# SQLite (default):
DATABASE_URL=sqlite:///data/datafinder.db

# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/datafinder

# ==========================================
# CORS Configuration
# ==========================================
CORS_ORIGINS=*

# ==========================================
# Embedding & Search Configuration
# ==========================================
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
DEFAULT_SEARCH_LIMIT=10
FAISS_INDEX_PATH=./data/datasets.faiss
FAISS_MAPPING_PATH=./data/datasets_mapping.json
FAISS_METADATA_PATH=./data/datasets_index_meta.json

# ==========================================
# Ingestion Pipeline Configuration
# ==========================================
INGESTION_INTERVAL_HOURS=6
BOOTSTRAP_QUERY=machine learning
ENABLE_SCHEDULER=false
ENABLE_STARTUP_INGESTION=true

# ==========================================
# Request & Logging Configuration
# ==========================================
REQUEST_TIMEOUT_SECONDS=15
USER_AGENT=datafinder-ai/1.0
LOG_DIR=./logs
LOG_FILE=./logs/app.log

# ==========================================
# LLM Configuration (Groq API)
# ==========================================
# Get API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# LLM Model (default: mixtral-8x7b-32768 for best reasoning)
# Other options: gemma-7b-it, llama-3.1-8b-instant, mixtral-8x7b-32768
LLM_MODEL=mixtral-8x7b-32768

# LLM Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# ==========================================
# DATA SOURCE API CREDENTIALS
# ==========================================

# GitHub API Token (Optional but recommended for higher rate limits)
# Get token from: https://github.com/settings/tokens
# Requires: 'public_repo' scope
GITHUB_TOKEN=

# OpenML API Key (Optional)
# Get key from: https://www.openml.org/api
OPENML_API_KEY=

# Mendeley Data API Credentials (Optional)
# Get credentials from: https://dev.mendeley.com/
# You need to create an app and get API Key and Secret
MENDELEY_API_KEY=
MENDELEY_API_SECRET=

# ==========================================
# Note: Zenodo and Papers with Code
# don't require authentication for basic searches
# ==========================================
